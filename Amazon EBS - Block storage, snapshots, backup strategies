SELECT

    storage_class,

    SUM(file_size_gb) AS total_storage,

    CASE

        WHEN storage_class =
             'STANDARD'

        THEN

            SUM(file_size_gb) *
            0.023

        WHEN storage_class =
             'GLACIER'

        THEN

            SUM(file_size_gb) *
            0.004

    END AS monthly_cost

FROM s3_storage_inventory

GROUP BY storage_class;

WITH standard_cost AS
(
    SELECT

        SUM(file_size_gb) *
        0.023 AS standard_price

    FROM s3_storage_inventory

    WHERE storage_class =
          'STANDARD'
),

glacier_cost AS
(
    SELECT

        SUM(file_size_gb) *
        0.004 AS glacier_price

    FROM s3_storage_inventory

    WHERE storage_class =
          'GLACIER'
)

SELECT

    standard_price,

    glacier_price,

    (
        standard_price -
        glacier_price
    ) AS monthly_savings,

    (
        standard_price -
        glacier_price
    ) * 12 AS yearly_savings

FROM standard_cost,
     glacier_cost;

SELECT

    bucket_name,

    COUNT(*) AS total_files,

    SUM(file_size_gb) AS total_storage,

    ROUND(
        SUM(file_size_gb) * 0.023,
        2
    ) AS standard_cost,

    ROUND(
        SUM(file_size_gb) * 0.004,
        2
    ) AS glacier_cost,

    ROUND(
        (
            SUM(file_size_gb) * 0.023
        ) -
        (
            SUM(file_size_gb) * 0.004
        ),
        2
    ) AS monthly_savings

FROM s3_storage_inventory


from pyspark.sql import SparkSession

spark = SparkSession.builder \
    .appName("S3Cost") \
    .getOrCreate()

data = [

    (
        "Source",
        1024,
        0.023
    ),

    (
        "Replica",
        1024,
        0.023
    )

]

df = spark.createDataFrame(
    data,
    [
        "location",
        "storage_gb",
        "cost_per_gb"
    ]
)

cost_df = df.withColumn(

    "monthly_cost",

    df.storage_gb *
    df.cost_per_gb

)

cost_df.show()
from pyspark.sql.functions import lit

transfer_df = cost_df.withColumn(

    "transfer_cost",

    lit(1024 * 0.02)

)

transfer_df.show()

DECLARE

    data_gb NUMBER := 1024;

    source_cost NUMBER;

    destination_cost NUMBER;

    transfer_cost NUMBER;

    total_cost NUMBER;

BEGIN

    source_cost :=

        data_gb * 0.023;

    destination_cost :=

        data_gb * 0.023;

    transfer_cost :=

        data_gb * 0.02;

    total_cost :=

        source_cost +
        destination_cost +
        transfer_cost;

    DBMS_OUTPUT.PUT_LINE(
        'Monthly Cost = ' ||
        total_cost
    );

END;
/

CREATE TABLE s3_replication_cost
(
    bucket_name VARCHAR2(100),

    region_name VARCHAR2(100),

    storage_gb NUMBER,

    storage_cost NUMBER,

    transfer_cost NUMBER
);

kubectl apply -f deployment.yaml
apiVersion: v1

kind: Service

metadata:
  name: ec2-service

spec:

  selector:
    app: ec2

  ports:
  - port: 80
    targetPort: 5000

  type: LoadBalancer

apiVersion: apps/v1
kind: Deployment

metadata:
  name: ec2-manager

spec:
  replicas: 3

  selector:
    matchLabels:
      app: ec2

  template:

    metadata:
      labels:
        app: ec2

    spec:

      containers:

      - name: ec2-manager

        image: ec2-manager:latest

        ports:
        - containerPort: 5000


import boto3

s3 = boto3.client('s3')

s3.create_bucket(

    Bucket='company-backup-bucket'
) // s3 bucket
s3.upload_file(

    'sales.csv',

    'company-backup-bucket',

    'sales.csv'
)

s3.put_bucket_versioning(

    Bucket='company-backup-bucket',

    VersioningConfiguration={
        'Status':'Enabled'
    }
)
s3.put_bucket_lifecycle_configuration(

    Bucket='company-backup-bucket',

    LifecycleConfiguration={
        'Rules':[
            {
                'ID':'Archive',

                'Status':'Enabled',

                'Transitions':[
                    {
                        'Days':30,

                        'StorageClass':
                        'GLACIER'
                    }
                ]
            }
        ]
    }
)

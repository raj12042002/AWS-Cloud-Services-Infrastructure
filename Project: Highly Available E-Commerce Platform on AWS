import boto3

ec2 = boto3.client('ec2')

response = ec2.create_vpc(
    CidrBlock='10.0.0.0/16'
)

print(
    response['Vpc']['VpcId']
)  // CREATE VPC

subnet = ec2.create_subnet(
    VpcId='vpc-id',
    CidrBlock='10.0.1.0/24'
)

print(subnet) // create public subnet

sg = ec2.create_security_group(
    GroupName='web-sg',
    Description='Web Access',
    VpcId='vpc-id'
)

print(sg['GroupId']) // cfreate security group

ec2.authorize_security_group_ingress(
    GroupId='sg-id',

    IpPermissions=[
        {
            'IpProtocol':'tcp',
            'FromPort':80,
            'ToPort':80,
            'IpRanges':[
                {
                    'CidrIp':'0.0.0.0/0'
                }
            ]
        }
    ]
)
instance = ec2.run_instances(

    ImageId='ami-id',

    InstanceType='t3.micro',

    MinCount=1,

    MaxCount=1
)

print(instance)

ec2.create_image(

    InstanceId='i-123456',

    Name='golden-image'
)
ec2.create_snapshot(

    VolumeId='vol-123456',

    Description='Daily Backup'
